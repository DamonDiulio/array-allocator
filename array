#include <iostream>
using namespace std;

// Function that dynamically allocates an array
int* allocateArray(int size) {
    int* arr = new int[size];
    return arr;
}

int main() {
    int num;

    cout << "How many elements do you want? ";
    cin >> num;

    // Call the function
    int* numbers = allocateArray(num);

    // Fill the array
    cout << "Enter " << num << " integers:\n";
    for (int i = 0; i < num; i++) {
        cin >> numbers[i];
    }

    // Display the array
    cout << "You entered: ";
    for (int i = 0; i < num; i++) {
        cout << numbers[i] << " ";
    }

    // Free the memory
    delete[] numbers;

    return 0;
}

